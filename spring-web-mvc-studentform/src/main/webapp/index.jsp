<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Student Registration System</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f0f4f8;
            margin: 0;
            padding: 0;
            text-align: center;
        }

        .container {
            margin-top: 120px;
        }

        h2 {
            color: #333;
            font-size: 28px;
            margin-bottom: 20px;
        }

        a {
            display: inline-block;
            text-decoration: none;
            background: #007bff;
            color: white;
            padding: 12px 22px;
            border-radius: 6px;
            font-size: 18px;
            transition: 0.3s;
        }

        a:hover {
            background: #0056b3;
        }
    </style>
</head>

<body>
    <div class="container">
        <h2>Welcome to Student Registration System</h2>

        <p>
            <a href="studentForm">Open Form</a>
        </p>
    </div>
</body>
</html>
